{% extends "layout/main.njk" %}

{% block title %}Meu Perfil - Builders AO{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto py-12 px-4 space-y-16">
    
    <!-- Perfil Header -->
    <div class="bg-white rounded-3xl shadow-premium border border-gray-100 p-8 sm:p-12 relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-8">
            <a href="/profile/edit" class="btn-shadcn flex items-center gap-2 hover:bg-gray-50 transition-all">
                <i data-lucide="edit-3" class="w-4 h-4"></i>
                Editar Perfil
            </a>
        </div>
        
        <div class="flex flex-col md:flex-row items-center md:items-start gap-8">
            <!-- Avatar -->
            <div class="relative group">
                <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-[2.5rem] bg-gray-50 border-4 border-white shadow-xl overflow-hidden relative z-10">
                    <img src="{{ user.user_metadata.avatar_url | default('https://ui-avatars.com/api/?name=' + user.email + '&background=random') }}" 
                         alt="Avatar" 
                         class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                </div>
                <div class="absolute -inset-2 bg-gradient-to-tr from-brand-red/20 to-transparent blur-2xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>

            <!-- Info -->
            <div class="flex-grow pt-4 text-center md:text-left space-y-4">
                <div class="space-y-1">
                    <h1 class="text-3xl sm:text-4xl font-black text-gray-900 tracking-tight">
                        {{ user.user_metadata.full_name | default("Builder s/ Nome") }}
                    </h1>
                    <p class="text-gray-500 font-medium flex items-center justify-center md:justify-start gap-2">
                        <i data-lucide="mail" class="w-4 h-4"></i>
                        {{ user.email }}
                    </p>
                </div>
                
                <div class="flex flex-wrap items-center justify-center md:justify-start gap-3">
                    <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-brand-light text-brand-red text-xs font-bold border border-red-100">
                        <i data-lucide="badge-check" class="w-3.5 h-3.5"></i>
                        Builder Oficial
                    </span>
                    <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-gray-50 text-gray-400 text-xs font-bold border border-gray-100">
                        <i data-lucide="calendar" class="w-3.5 h-3.5"></i>
                        Membro desde 2026
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Seção de Produtos -->
    <div class="space-y-8">
        <div class="flex items-center justify-between">
            <h2 class="text-2xl font-bold tracking-tight text-gray-900 flex items-center gap-3">
                <i data-lucide="package" class="w-6 h-6 text-brand-red"></i>
                Meus Projetos
            </h2>
            <p class="text-sm font-medium text-gray-500 bg-gray-50 px-4 py-2 rounded-xl">
                Total: {{ products.length }}
            </p>
        </div>

        {% if products and products.length > 0 %}
            <div class="grid grid-cols-1 gap-6">
                {% for product in products %}
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 flex flex-col sm:flex-row items-center gap-6 group hover:shadow-premium hover:border-gray-200 transition-all duration-300">
                        
                        <!-- Logo -->
                        <div class="w-20 h-20 shrink-0 bg-gray-50 rounded-2xl flex items-center justify-center border border-gray-50 overflow-hidden">
                            {% if product.logo_url %}
                                <img src="{{ product.logo_url }}" alt="Logo {{ product.name }}" class="max-h-full max-w-full object-cover">
                            {% else %}
                                <i data-lucide="package" class="w-8 h-8 text-gray-200"></i>
                            {% endif %}
                        </div>

                        <!-- Info -->
                        <div class="flex-grow text-center sm:text-left min-w-0">
                            <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
                                <h3 class="text-lg font-bold text-gray-900 truncate">{{ product.name }}</h3>
                                <div class="flex justify-center sm:justify-start">
                                    {% if product.status == 'published' %}
                                        <span class="px-2 py-0.5 rounded-full bg-green-50 text-green-600 text-[10px] font-bold border border-green-100">Publicado</span>
                                    {% else %}
                                        <span class="px-2 py-0.5 rounded-full bg-yellow-50 text-yellow-600 text-[10px] font-bold border border-yellow-100">Em análise</span>
                                    {% endif %}
                                </div>
                            </div>
                            <p class="text-sm text-gray-500 mb-4 line-clamp-1 italic">{{ product.taglines | default('Sem descrição curta.') }}</p>
                            
                            <div class="flex items-center justify-center sm:justify-start gap-4">
                                <div class="flex items-center gap-1.5 text-gray-400 text-xs">
                                    <i data-lucide="arrow-up-circle" class="w-3.5 h-3.5 text-brand-red"></i>
                                    <span class="font-bold">{{ product.upvotes_count }} upvotes</span>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="flex items-center gap-2">
                            <a href="/edit-product/{{ product.id }}" class="p-2 text-gray-400 hover:text-brand-red hover:bg-brand-light rounded-xl transition-all" title="Editar">
                                <i data-lucide="edit-2" class="w-5 h-5"></i>
                            </a>
                            <button onclick="confirmDeletion('{{ product.id }}', '{{ product.name }}')" class="p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition-all" title="Eliminar">
                                <i data-lucide="trash-2" class="w-5 h-5"></i>
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="py-20 flex flex-col items-center justify-center bg-gray-50 rounded-3xl border border-dashed border-gray-200">
                <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-sm mb-6">
                    <i data-lucide="package-plus" class="w-8 h-8 text-gray-300"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Você ainda não enviou projetos!</h3>
                <p class="text-gray-500 text-center max-w-sm mb-8 italic">Seu portfólio está vazio. Mostre ao mundo o que você está construindo.</p>
                <a href="/submit" class="bg-gray-900 text-white px-8 py-4 rounded-xl font-bold hover:bg-black transition flex items-center gap-2 shadow-lg">
                    <i data-lucide="rocket" class="w-5 h-5"></i>
                    Lançar Primeiro Produto
                </a>
            </div>
        {% endif %}
    </div>
</div>

<!-- Deletion Confirmation Modal (Shadcn style) -->
<div id="delete-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm transition-opacity">
    <div class="bg-white rounded-2xl shadow-premium max-w-sm w-full overflow-hidden transform transition-all scale-95 opacity-0" id="delete-modal-content">
        <div class="p-6 text-center">
            <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-4 text-red-600">
                <i data-lucide="alert-triangle" class="w-8 h-8"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Eliminar Projeto?</h3>
            <p class="text-gray-500 text-sm mb-6">Tem certeza que deseja eliminar "<span id="product-name-display" class="font-bold text-gray-900"></span>"? Esta ação não pode ser desfeita.</p>
            
            <form id="delete-form" method="POST">
                <div class="flex flex-col gap-3">
                    <button type="submit" class="w-full bg-red-600 text-white px-4 py-3 rounded-xl font-bold hover:bg-red-700 transition flex items-center justify-center gap-2">
                        Sim, eliminar projeto
                    </button>
                    <button type="button" onclick="closeDeleteModal()" class="w-full text-gray-500 text-sm font-medium hover:text-gray-900 transition mt-2">
                        Cancelar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function confirmDeletion(id, name) {
        const modal = document.getElementById('delete-modal');
        const content = document.getElementById('delete-modal-content');
        const nameDisplay = document.getElementById('product-name-display');
        const form = document.getElementById('delete-form');
        
        nameDisplay.textContent = name;
        form.action = `/products/${id}/delete`;
        
        modal.classList.remove('hidden');
        setTimeout(() => {
            content.classList.remove('scale-95', 'opacity-0');
            content.classList.add('scale-100', 'opacity-100');
        }, 10);
    }

    function closeDeleteModal() {
        const modal = document.getElementById('delete-modal');
        const content = document.getElementById('delete-modal-content');
        content.classList.remove('scale-100', 'opacity-100');
        content.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 200);
    }

    document.getElementById('delete-modal').addEventListener('click', (e) => {
        if (e.target.id === 'delete-modal') closeDeleteModal();
    });
</script>
{% endblock %}
