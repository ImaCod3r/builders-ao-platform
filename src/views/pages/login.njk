{% extends "layout/main.njk" %}

{% block title %}Entrar - Builders AO{% endblock %}

{% block content %}
<div class="flex-grow flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-xl shadow-2xl border border-red-100">
        
        <!-- Cabeçalho do Login -->
        <div class="text-center">
            <!-- Ícone/Logo centralizado -->
            <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-brand-light mb-4 shadow-sm border border-red-50">
                <svg class="w-10 h-10 text-brand-red" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zm0 7.5L3.5 7 12 4.5 20.5 7 12 9.5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            </div>
            
            <h2 class="mt-2 text-3xl font-extrabold text-gray-900">
                Acesse sua conta
            </h2>
            <p class="mt-2 text-sm text-gray-600">
                Faça login para enviar e gerenciar seus projetos no ecossistema Builders AO.
            </p>
        </div>

        <!-- Mensagem de Erro (se houver) -->
        {% if error %}
            <div class="bg-red-50 border-l-4 border-brand-red p-4 rounded-md">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <svg class="h-5 w-5 text-brand-red" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm text-brand-darkred font-medium">
                            Falha na autenticação. Por favor, tente novamente.
                        </p>
                    </div>
                </div>
            </div>
        {% endif %}

        <!-- Botão de Ação -->
        <div class="mt-8">
            <a href="/auth/login" class="group relative w-full flex justify-center py-3 px-4 border border-gray-300 rounded-md shadow-sm bg-white text-md font-bold text-gray-700 hover:bg-gray-50 hover:text-brand-red focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-red transition-all duration-200 ease-in-out">
                <span class="absolute left-0 inset-y-0 flex items-center pl-3">
                    <!-- Ícone do Google -->
                    <svg class="h-5 w-5 group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12.24 10.285V14.4h6.806c-.275 1.765-2.056 5.174-6.806 5.174-4.095 0-7.439-3.389-7.439-7.574s3.345-7.574 7.439-7.574c2.33 0 3.891.989 4.785 1.849l3.254-3.138C18.189 1.186 15.479 0 12.24 0 5.665 0 .24 5.373.24 12s5.425 12 12 12c6.926 0 11.52-4.869 11.52-11.726 0-.788-.085-1.39-.189-1.989H12.24z"/>
                    </svg>
                </span>
                Continuar com o Google
            </a>
        </div>

        <!-- Termos e Condições (opcional visualmente bonito) -->
        <p class="mt-4 text-center text-xs text-gray-500">
            Ao fazer login, você concorda com nossos
            <a href="#" class="font-medium text-brand-red hover:text-brand-darkred">Termos de Serviço</a> e
            <a href="#" class="font-medium text-brand-red hover:text-brand-darkred">Política de Privacidade</a>.
        </p>

    </div>
</div>
{% endblock %}
