{% extends "layout/main.njk" %}

{% block title %}Início - Builders AO{% endblock %}

{% block content %}

<!-- Layout adaptado -->
<div class="max-w-5xl mx-auto space-y-12">
    {% if projects and projects.length > 0 %}
        
        <!-- Seção: Destaques -->
        <div>
            <div class="flex items-center gap-2 mb-4">
                <svg class="w-5 h-5 text-brand-red" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <h2 class="text-sm font-bold tracking-wider text-gray-500 uppercase">Destaques</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for project in projects.slice(0, 6) %}
                    <a href="/product/{{ project.slug }}" class="flex items-center gap-4 bg-white border border-gray-100 p-4 rounded-xl shadow-sm hover:border-brand-red hover:shadow-md transition duration-300">
                        <!-- Logo -->
                        <div class="w-12 h-12 flex-shrink-0 bg-brand-light rounded-lg flex items-center justify-center border border-gray-50 overflow-hidden">
                            {% if project.logo_url %}
                                <img src="{{ project.logo_url }}" alt="Logo {{ project.name }}" class="max-h-full max-w-full object-contain">
                            {% else %}
                                <span class="text-brand-red opacity-50 font-bold text-[10px] uppercase text-center leading-tight">Sem Logo</span>
                            {% endif %}
                        </div>
                        <!-- Info -->
                        <div class="flex-grow overflow-hidden">
                            <h3 class="text-sm font-bold text-gray-900 truncate">{{ project.name }}</h3>
                            <p class="text-xs text-gray-500 line-clamp-1">
                                {% if project.taglines %}
                                    {{ project.taglines.split(',')[0] | trim }}
                                {% else %}
                                    Lançamento recente
                                {% endif %}
                            </p>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </div>

        <!-- Seção: Produtos mais recentes -->
        <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Produtos da Comunidade</h2>
            <div class="flex flex-col gap-4">
                {% for project in projects %}
                    <div class="relative bg-white rounded-xl shadow-sm border border-gray-100 p-4 hover:shadow-md transition duration-300 flex items-center gap-4 sm:gap-6 group">
                        
                        <a href="/product/{{ project.slug }}" class="absolute inset-0 z-10"><span class="sr-only">Ver produto {{ project.name }}</span></a>

                        <!-- Rank -->
                        <div class="text-brand-red font-bold text-sm w-6 text-center hidden sm:block">
                            #{{ loop.index }}
                        </div>

                        <!-- Logo Section -->
                        <div class="w-16 h-16 sm:w-20 sm:h-20 flex-shrink-0 bg-brand-light rounded-lg flex items-center justify-center border border-gray-50 overflow-hidden">
                            {% if project.logo_url %}
                                <img src="{{ project.logo_url }}" alt="Logo {{ project.name }}" class="max-h-full max-w-full object-contain">
                            {% else %}
                                <span class="text-brand-red opacity-50 font-bold text-xs uppercase text-center leading-tight">Sem Logo</span>
                            {% endif %}
                        </div>

                        <!-- Infos do Projeto -->
                        <div class="flex-grow py-1">
                            <h3 class="text-lg sm:text-xl font-bold text-gray-900 leading-tight mb-1 group-hover:text-brand-red transition-colors">
                                {{ project.name }}
                            </h3>
                            
                            <!-- Descrição / Taglines resumidas como descrição -->
                            <p class="text-sm text-gray-600 mb-2 line-clamp-1 sm:line-clamp-2">
                                {% if project.taglines %}
                                    {{ project.taglines }}
                                {% else %}
                                    Produto sem descrição no momento.
                                {% endif %}
                            </p>

                            <!-- Tags -->
                            <div class="flex flex-wrap items-center gap-2">
                                {% if project.taglines %}
                                    {% set tags = project.taglines.split(',') %}
                                    {% for tag in tags %}
                                        {% if loop.index0 < 2 %}
                                            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] sm:text-xs font-medium bg-gray-100 text-gray-600">
                                                {{ tag | trim }}
                                            </span>
                                        {% endif %}
                                    {% endfor %}
                                {% endif %}
                                {% if loop.index <= 3 %}
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] sm:text-xs font-medium bg-red-50 text-brand-red">
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                                        Destaque
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                        <!-- Upvote Section (Right aligned) -->
                        <div class="flex-shrink-0 ml-2 relative z-20">
                            <button 
                                class="upvote-btn flex flex-col items-center justify-center p-2 min-w-[50px] sm:min-w-[60px] border rounded-lg transition-colors {{ 'border-brand-red text-brand-red bg-red-50' if project.has_upvoted else 'border-gray-200 text-gray-500 hover:border-brand-red hover:text-brand-red hover:bg-red-50' }}"
                                data-id="{{ project.id }}"
                                aria-label="Upvote">
                                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
                                </svg>
                                <span class="font-bold text-sm sm:text-base upvote-count mt-1">{{ project.upvotes_count }}</span>
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>

    {% else %}
        <div class="col-span-full py-16 flex flex-col items-center justify-center bg-white rounded-xl shadow-sm border border-dashed border-red-200">
            <svg class="w-16 h-16 text-brand-red opacity-30 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Nenhum projeto encontrado!</h3>
            <p class="text-gray-500 text-center max-w-md">Parece que ainda não há projetos aprovados ou disponíveis no momento. Faça login e seja o primeiro a enviar!</p>
        </div>
    {% endif %}
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const upvoteBtns = document.querySelectorAll('.upvote-btn');
    
    upvoteBtns.forEach(btn => {
        btn.addEventListener('click', async (e) => {
            // Prevent default just in case, and find closest btn if inner icon clicked
            const currentBtn = e.target.closest('button');
            const productId = currentBtn.dataset.id;
            
            try {
                const response = await fetch(`/products/${productId}/upvote`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                if (response.status === 401 || response.status === 403) {
                    // Redirect to login or show alert
                    window.location.href = '/login?error=' + encodeURIComponent('Faça login para dar upvote.');
                    return;
                }

                if (!response.ok) {
                    throw new Error('Falha ao processar upvote');
                }

                const data = await response.json();
                
                // Update UI based on action
                const countSpan = currentBtn.querySelector('.upvote-count');
                countSpan.textContent = data.count;
                
                if (data.action === 'added') {
                    currentBtn.classList.remove('text-gray-400', 'hover:bg-gray-50', 'hover:text-brand-red');
                    currentBtn.classList.add('text-brand-red', 'bg-red-50');
                } else if (data.action === 'removed') {
                    currentBtn.classList.remove('text-brand-red', 'bg-red-50');
                    currentBtn.classList.add('text-gray-400', 'hover:bg-gray-50', 'hover:text-brand-red');
                }
            } catch (error) {
                console.error(error);
                alert('Erro ao processar o seu upvote.');
            }
        });
    });
});
</script>

{% endblock %}
