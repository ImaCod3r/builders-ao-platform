{% extends "layout/main.njk" %}

{% block title %}Dashboard Admin - Builders AO{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto">
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 border-l-4 border-brand-red pl-3">Painel Administrativo</h1>
            <p class="text-gray-600 mt-2">Gerencie os projetos submetidos na plataforma.</p>
        </div>
    </div>

    {% if success %}
        <div class="bg-green-50 text-green-700 border border-green-200 p-4 rounded-md mb-6" role="alert">
            Projeto atualizado com sucesso ({{ success }}).
        </div>
    {% endif %}

    {% if error %}
        <div class="bg-red-50 text-brand-red border border-red-200 p-4 rounded-md mb-6" role="alert">
            {{ error }}
        </div>
    {% endif %}

    <div class="bg-white shadow rounded-lg overflow-hidden border border-gray-100">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
            <h2 class="text-lg font-bold text-gray-800">Projetos Pendentes de Aprovação</h2>
            <span class="bg-amber-100 text-amber-800 text-xs font-semibold px-2.5 py-0.5 rounded-full">{{ pendingProjects | length }}</span>
        </div>
        
        {% if pendingProjects and pendingProjects.length > 0 %}
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50 uppercase text-xs text-gray-500 font-semibold tracking-wider">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left">Logo</th>
                        <th scope="col" class="px-6 py-3 text-left">Projeto</th>
                        <th scope="col" class="px-6 py-3 text-left">URL</th>
                        <th scope="col" class="px-6 py-3 text-left">Tags</th>
                        <th scope="col" class="px-6 py-3 text-right">Ações</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for project in pendingProjects %}
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <img src="{{ project.logo_url }}" alt="Logo {{ project.name }}" class="h-10 w-10 rounded shadow-sm object-cover bg-white" onerror="this.src='https://ui-avatars.com/api/?name={{ project.name }}&background=E5E7EB&color=374151'">
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm font-bold text-gray-900">{{ project.name }}</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <a href="{{ project.url }}" target="_blank" class="text-brand-red hover:text-brand-darkred text-sm font-medium hover:underline flex items-center gap-1">
                                Visitar Site
                            </a>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-wrap gap-1">
                                {% if project.taglines %}
                                    {% set tags = project.taglines.split(',') %}
                                    {% for tag in tags %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800 border border-gray-200">
                                            {{ tag | trim }}
                                        </span>
                                    {% endfor %}
                                {% else %}
                                    <span class="text-gray-400 text-xs italic">Sem tags</span>
                                {% endif %}
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                            <div class="flex items-center justify-end gap-2">
                                <!-- Botão de Aprovar -->
                                <form action="/admin/projects/{{ project.id }}/approve" method="POST" class="inline-block m-0">
                                    <button type="submit" class="bg-green-600 hover:bg-green-700 text-white font-bold py-1.5 px-3 rounded shadow-sm transition-colors text-xs flex items-center gap-1">
                                        Aprovar
                                    </button>
                                </form>
                                <!-- Botão de Rejeitar -->
                                <form action="/admin/projects/{{ project.id }}/reject" method="POST" class="inline-block m-0">
                                    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-bold py-1.5 px-3 rounded shadow-sm transition-colors text-xs flex items-center gap-1" onclick="return confirm('Quer rejeitar o projeto {{ project.name }}?');">
                                        Rejeitar
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="p-10 text-center">
            <h3 class="text-lg font-medium text-gray-900 mt-2">Nenhum projeto pendente</h3>
            <p class="mt-1 text-sm text-gray-500">Tudo limpo por aqui! Nenhuma submissão aguardando aprovação no momento.</p>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
