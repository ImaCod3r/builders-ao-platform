{% extends "layout/main.njk" %}

{% block title %}{{ product.name }} - Builders AO{% endblock %}

{% block description %}{{ product.description }} - Saiba mais sobre o projeto {{ product.name }} na Builders AO.{% endblock %}

{% block ogTitle %}{{ product.name }} - Builders AO{% endblock %}
{% block ogDescription %}{{ product.description }}{% endblock %}
{% block ogImage %}{{ product.logo_url or 'https://buildersangola.tech/assets/logo.png' }}{% endblock %}

{% block twitterTitle %}{{ product.name }} - Builders AO{% endblock %}
{% block twitterDescription %}{{ product.taglines }}{% endblock %}
{% block twitterImage %}{{ product.logo_url or 'https://buildersangola.tech/assets/logo.png' }}{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto py-12 px-4 sm:px-6">
    
    <!-- Breadcrumbs -->
    <nav class="flex mb-8 text-sm font-medium text-gray-500 items-center gap-2">
        <a href="/" class="hover:text-brand-red transition-colors">Início</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="text-gray-900">{{ product.name }}</span>
    </nav>

    <div class="bg-white rounded-3xl shadow-premium border border-gray-100 overflow-hidden">
        <!-- Header Section -->
        <div class="p-6 sm:p-10">
            <div class="flex flex-col lg:flex-row items-center lg:items-start gap-8 lg:gap-10">
                
                <!-- Logo & Creator Section -->
                <div class="w-full lg:w-auto flex flex-col items-center gap-6">
                    <div class="w-28 h-28 sm:w-32 sm:h-32 flex items-center justify-center overflow-hidden rounded-3xl transition-transform hover:scale-105 bg-gray-50 border border-gray-100 shadow-sm">
                        {% if product.logo_url %}
                            <img src="{{ product.logo_url }}" alt="Logo {{ product.name }}" class="h-full w-full object-cover">
                        {% else %}
                            <i data-lucide="package" class="w-12 h-12 text-gray-200"></i>
                        {% endif %}
                    </div>

                    <!-- Creator Info -->
                    <div class="flex items-center gap-3 px-3 py-2 rounded-2xl bg-gray-50/50 border border-gray-100 group transition-colors hover:bg-gray-50">
                        <div class="w-10 h-10 rounded-full border-2 border-white shadow-sm overflow-hidden shrink-0 group-hover:scale-110 transition-transform">
                            <img src="{{ product.creator.avatar_url | default('https://ui-avatars.com/api/?name=' + product.creator.full_name + '&background=random') }}" 
                                 class="w-full h-full object-cover" 
                                 alt="Avatar de {{ product.creator.full_name }}">
                        </div>
                        <div>
                            <p class="text-[9px] text-gray-400 uppercase font-black tracking-widest leading-none mb-1">Criado por</p>
                            <p class="text-xs font-bold text-gray-900 leading-none">{{ product.creator.full_name | default("Builder") }}</p>
                        </div>
                    </div>
                </div>

                <!-- Info Section -->
                <div class="flex-grow text-center lg:text-left space-y-6">
                    <div class="space-y-4">
                        <h1 class="text-3xl sm:text-5xl lg:text-6xl font-black text-gray-900 tracking-tighter leading-[0.9] sm:leading-tight">{{ product.name }}</h1>
                        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-2">
                            {% if product.taglines %}
                                {% set tags = product.taglines.split(',') %}
                                {% for tag in tags %}
                                    <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-xs font-bold bg-white text-gray-600 border border-gray-200 shadow-sm uppercase tracking-wider">
                                        {{ tag | trim }}
                                    </span>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                </div>

                <!-- Action Button -->
                <div class="w-full lg:w-auto flex flex-col sm:flex-row lg:flex-col gap-3 min-w-[200px]">
                    <button 
                        class="upvote-btn flex-1 lg:w-full flex items-center justify-center gap-3 py-4 px-8 rounded-2xl border-2 transition-all duration-200 font-bold {{ 'border-brand-red bg-brand-light text-brand-red shadow-inner' if product.has_upvoted else 'border-gray-100 bg-white text-gray-400 hover:border-brand-red hover:text-brand-red hover:bg-brand-light hover:shadow-lg' }}"
                        data-id="{{ product.id }}"
                        data-is-logged="{{ 'true' if user else 'false' }}"
                        aria-label="Upvote">
                        <i data-lucide="chevron-up" class="w-6 h-6 {{ 'animate-bounce' if not product.has_upvoted }}"></i>
                        <span class="text-xl upvote-count">{{ product.upvotes_count }}</span>
                    </button>
                    
                    {% if product.url %}
                        <a href="{{ product.url }}" target="_blank" rel="noopener noreferrer" class="flex-1 lg:w-full flex items-center justify-center gap-2 px-8 py-4 bg-gray-900 border border-transparent text-white rounded-2xl font-bold hover:bg-black transition-all shadow-lg hover:shadow-xl active:scale-95">
                            Visitar
                            <i data-lucide="external-link" class="w-4 h-4"></i>
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Product Shots Carousel -->
        {% if product.product_images and product.product_images.length > 0 %}
            <div class="px-6 sm:px-10 py-8 bg-gray-50/50">
                <div class="flex items-center gap-2 mb-6">
                    <i data-lucide="gallery-horizontal" class="w-5 h-5 text-brand-red"></i>
                    <h2 class="text-xl font-bold text-gray-900">Product Shots</h2>
                </div>
                
                <div class="relative group">
                    <div id="carousel-track" class="flex overflow-x-auto snap-x snap-mandatory gap-4 pb-4">
                        {% for image in product.product_images | sort(attribute='sort_order') %}
                            <div class="flex-shrink-0 w-[85%] sm:w-[70%] aspect-video snap-center">
                                <div class="w-full h-full rounded-2xl overflow-hidden border border-gray-100 shadow-sm bg-white">
                                    <img src="{{ image.url }}" alt="{{ product.name }} shot {{ loop.index }}" class="w-full h-full object-cover">
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            <div class="h-px bg-gradient-to-r from-transparent via-gray-100 to-transparent mx-8"></div>
        {% endif %}

        <!-- Content Divider -->
        <div class="h-px bg-gradient-to-r from-transparent via-gray-100 to-transparent mx-8"></div>

        <!-- Description Section -->
        <div class="p-6 sm:p-10 space-y-4">
            <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
                <i data-lucide="text-quote" class="w-6 h-6 text-brand-red"></i>
                Sobre o projeto
            </h2>
            <div class="prose max-w-none text-gray-600 leading-relaxed text-lg whitespace-pre-line">
                {% if product.description %}
                    {{ product.description }}
                {% else %}
                    <div class="bg-gray-50 rounded-2xl p-8 text-center border border-dashed border-gray-200 uppercase tracking-widest text-xs font-bold text-gray-400">
                        Nenhuma descrição fornecida pelo autor.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    
    <div class="mt-12 flex justify-center">
        <a href="/" class="flex items-center gap-2 text-gray-500 hover:text-brand-red font-bold transition-colors py-2 px-4 rounded-xl hover:bg-brand-light">
            <i data-lucide="arrow-left" class="w-5 h-5"></i>
            Voltar para a comunidade
        </a>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const upvoteBtn = document.querySelector('.upvote-btn');
    
    if (upvoteBtn) {
        upvoteBtn.addEventListener('click', async (e) => {
            const currentBtn = e.currentTarget;
            const productId = currentBtn.dataset.id;
            const isLogged = currentBtn.dataset.isLogged === 'true';

            if (!isLogged) {
                openModal(
                    'Apoie este Projeto', 
                    'Faça login para dar o seu upvote e ajudar este builder a crescer na nossa comunidade.'
                );
                return;
            }
            
            // Add loading state
            currentBtn.classList.add('opacity-50', 'pointer-events-none');

            try {
                const response = await fetch(`/products/${productId}/upvote`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                if (response.status === 401 || response.status === 403) {
                    openModal('Sessão Expirada', 'Por favor, faça login novamente para continuar.');
                    return;
                }

                if (!response.ok) throw new Error('Falha ao processar upvote');

                const data = await response.json();
                
                const countSpan = currentBtn.querySelector('.upvote-count');
                countSpan.textContent = data.count;
                
                if (data.action === 'added') {
                    currentBtn.classList.remove('border-gray-100', 'bg-white', 'text-gray-400');
                    currentBtn.classList.add('border-brand-red', 'bg-brand-light', 'text-brand-red');
                } else if (data.action === 'removed') {
                    currentBtn.classList.remove('border-brand-red', 'bg-brand-light', 'text-brand-red');
                    currentBtn.classList.add('border-gray-100', 'bg-white', 'text-gray-400');
                }
            } catch (error) {
                console.error(error);
                alert('Erro ao processar o seu upvote.');
            } finally {
                currentBtn.classList.remove('opacity-50', 'pointer-events-none');
            }
        });
    }
});
</script>
{% endblock %}