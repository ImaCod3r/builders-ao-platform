{% extends "layout/main.njk" %}

{% block title %}Início - Builders AO{% endblock %}

{% block content %}
<div class="text-center mb-16">
    <h1 class="text-4xl md:text-5xl font-extrabold text-brand-red mb-4">Galeria de Projetos</h1>
    <p class="text-lg text-gray-700 max-w-2xl mx-auto">
        Explore as incríveis iniciativas da nossa comunidade. Aqui você encontra todos os projetos que já foram aprovados e estão moldando o ecossistema.
    </p>
</div>

<!-- Grid de Projetos Aprovados -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
    {% if projects and projects.length > 0 %}
        {% for project in projects %}
            <div class="bg-white rounded-xl shadow-lg border border-red-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition duration-300">
                
                <!-- Container da Logo -->
                <div class="h-48 bg-brand-light flex items-center justify-center border-b border-red-50 p-4">
                    {% if project.logoUrl %}
                        <img src="{{ project.logoUrl }}" alt="Logo {{ project.name }}" class="max-h-full max-w-full object-contain">
                    {% else %}
                        <span class="text-brand-red opacity-50 font-bold text-xl">Sem Logo</span>
                    {% endif %}
                </div>

                <!-- Infos do Projeto -->
                <div class="p-6">
                    <h2 class="text-xl font-bold text-gray-900 mb-2">{{ project.name }}</h2>
                    <p class="text-gray-600 text-sm line-clamp-3 mb-4">
                        {{ project.description }}
                    </p>
                    
                    <div class="pt-4 border-t border-gray-100 flex justify-between items-center">
                        <span class="inline-block px-3 py-1 bg-green-100 text-green-700 text-xs font-semibold rounded-full">
                            Aprovado
                        </span>
                        {% if project.link %}
                            <a href="{{ project.link }}" target="_blank" rel="noopener noreferrer" class="text-brand-red hover:text-brand-darkred text-sm font-semibold flex items-center gap-1">
                                Visitar <span>&rarr;</span>
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    {% else %}
        <div class="col-span-full py-16 flex flex-col items-center justify-center bg-white rounded-xl shadow-sm border border-dashed border-red-200">
            <svg class="w-16 h-16 text-brand-red opacity-30 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Nenhum projeto encontrado!</h3>
            <p class="text-gray-500 text-center max-w-md">Parece que ainda não há projetos aprovados ou disponíveis no momento. Faça login e seja o primeiro a enviar!</p>
        </div>
    {% endif %}
</div>
{% endblock %}
