{% extends "layout/main.njk" %}

{% block title %}Submeter Projeto - Builders AO{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto py-12 px-4">
    <div class="space-y-10">
        <div class="text-center">
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight mb-3">Submeter Novo Projeto</h1>
            <p class="text-gray-500 max-w-sm mx-auto">Compartilhe sua criação com a comunidade de builders angolanos e ganhe visibilidade.</p>
        </div>

        {% if error %}
            <div class="bg-red-50 text-brand-red border border-red-100 p-4 rounded-2xl flex items-center gap-3 animate-shake" role="alert">
                <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i>
                <span class="text-sm font-semibold">{{ error }}</span>
            </div>
        {% endif %}

        <form action="/submit" method="POST" enctype="multipart/form-data" class="space-y-8 bg-white p-8 sm:p-10 rounded-3xl shadow-premium border border-gray-100 transition-all">
            
            <!-- Upload da Logo Section -->
            <div class="space-y-4">
                <label class="text-sm font-bold text-gray-700 tracking-tight flex items-center gap-2">
                    <i data-lucide="image" class="w-4 h-4 text-brand-red"></i>
                    Logo do Projeto
                </label>
                <div class="flex items-center gap-6 p-4 border-2 border-dashed border-gray-100 rounded-2xl bg-gray-50/50 group transition-colors hover:border-gray-200">
                    <div class="relative w-20 h-20 sm:w-24 sm:h-24 shrink-0 bg-white rounded-xl flex items-center justify-center border border-gray-100 overflow-hidden shadow-sm shadow-gray-200/50">
                        <img id="logo-preview" class="absolute inset-0 h-full w-full object-cover opacity-0 group-data-[has-file=true]:opacity-100 transition-opacity" src="" alt="" />
                        <i id="logo-placeholder" data-lucide="upload-cloud" class="w-8 h-8 text-gray-300 group-data-[has-file=true]:hidden"></i>
                    </div>
                    <div class="flex-grow">
                        <label class="cursor-pointer">
                            <span class="btn-shadcn bg-white hover:bg-gray-50 transition-all">Selecionar Imagem</span>
                            <input type="file" id="logo-input" name="logo" accept="image/*" class="sr-only"/>
                        </label>
                        <p class="text-[10px] text-gray-400 mt-2 font-medium uppercase tracking-wider">PNG, JPG ou WEBP. Máx 2MB.</p>
                    </div>
                </div>
            </div>

            <!-- Product Shots Section -->
            <div class="space-y-4">
                <label class="text-sm font-bold text-gray-700 tracking-tight flex items-center gap-2">
                    <i data-lucide="gallery-thumbnails" class="w-4 h-4 text-brand-red"></i>
                    Screenshots / Product Shots
                </label>
                <div class="p-6 border-2 border-dashed border-gray-100 rounded-3xl bg-gray-50/30 group transition-all hover:border-gray-200">
                    <div id="shots-preview-container" class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-4 hidden">
                        <!-- Previews will appear here -->
                    </div>
                    <label class="flex flex-col items-center justify-center py-8 cursor-pointer group/label">
                        <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-sm border border-gray-100 group-hover/label:scale-110 transition-transform">
                            <i data-lucide="plus" class="w-6 h-6 text-brand-red"></i>
                        </div>
                        <p class="mt-4 text-sm font-bold text-gray-700">Adicionar fotos do produto</p>
                        <p class="mt-1 text-[10px] text-gray-400 uppercase tracking-widest font-medium">Até 5 imagens • Máx 2MB cada</p>
                        <input type="file" id="images-input" name="images" accept="image/*" multiple class="sr-only"/>
                    </label>
                </div>
            </div>
            <div class="grid grid-cols-1 gap-6">
                <!-- Nome do Projeto -->
                <div class="space-y-2">
                    <label for="name" class="text-sm font-bold text-gray-700 tracking-tight">Nome do Projeto</label>
                    <input type="text" id="name" name="name" required placeholder="Como se chama seu projeto?" 
                           class="w-full bg-gray-50 border border-gray-100 rounded-xl px-4 py-3.5 text-sm focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-red/10 focus:border-brand-red transition-all placeholder:text-gray-400" />
                </div>

                <!-- URL do Projeto -->
                <div class="space-y-2">
                    <label for="url" class="text-sm font-bold text-gray-700 tracking-tight">Endereço (Link)</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i data-lucide="link" class="w-4 h-4 text-gray-300"></i>
                        </div>
                        <input type="url" id="url" name="url" placeholder="https://meuprojeto.ao" 
                               class="w-full bg-gray-50 border border-gray-100 rounded-xl pl-11 pr-4 py-3.5 text-sm focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-red/10 focus:border-brand-red transition-all placeholder:text-gray-400" />
                    </div>
                </div>

                <!-- Taglines -->
                <div class="space-y-2">
                    <label for="taglines" class="text-sm font-bold text-gray-700 tracking-tight">Tags (Separadas por vírgula)</label>
                    <input type="text" id="taglines" name="taglines" placeholder="ex: Fintech, Open Source, Educação" 
                           class="w-full bg-gray-50 border border-gray-100 rounded-xl px-4 py-3.5 text-sm focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-red/10 focus:border-brand-red transition-all placeholder:text-gray-400" />
                </div>

                <!-- Description -->
                <div class="space-y-2">
                    <label for="description" class="text-sm font-bold text-gray-700 tracking-tight">Apresentação</label>
                    <textarea id="description" name="description" rows="5" placeholder="Conte a história por trás do seu projeto, o problema que ele resolve e quem ele atende..." 
                              class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-4 py-3.5 text-sm focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-red/10 focus:border-brand-red transition-all placeholder:text-gray-400 resize-none"></textarea>
                </div>
            </div>

            <!-- Botões de Ação -->
            <div class="pt-6 flex flex-col sm:flex-row items-center gap-3">
                <button type="submit" class="w-full sm:w-auto bg-gray-900 text-white px-8 py-4 rounded-xl font-bold hover:bg-black transition-all shadow-lg active:scale-95 flex items-center justify-center gap-2">
                    <i data-lucide="send" class="w-4 h-4"></i>
                    Publicar Projeto
                </button>
                <a href="/" class="w-full sm:w-auto text-center px-8 py-4 text-gray-500 font-bold hover:text-gray-900 transition-colors">
                    Cancelar
                </a>
            </div>
        </form>
        
        <div class="text-center">
            <p class="text-xs text-gray-400 font-medium uppercase tracking-[0.2em]">Builders Angola &copy; 2026</p>
        </div>
    </div>
</div>

<script>
    const MAX_SIZE = 2 * 1024 * 1024; // 2MB

    const logoInput = document.getElementById('logo-input');
    const logoPreview = document.getElementById('logo-preview');
    const container = logoInput.closest('div.flex');

    logoInput.addEventListener('change', function() {
        if (this.files && this.files[0]) {
            if (this.files[0].size > MAX_SIZE) {
                alert('A logo excede o tamanho máximo de 2MB. Por favor, escolha uma imagem menor.');
                this.value = '';
                logoPreview.src = '';
                container.removeAttribute('data-has-file');
                return;
            }
            const reader = new FileReader();
            reader.onload = function(e) {
                logoPreview.src = e.target.result;
                container.setAttribute('data-has-file', 'true');
            }
            reader.readAsDataURL(this.files[0]);
        } else {
            logoPreview.src = "";
            container.removeAttribute('data-has-file');
        }
    });
    
    const imagesInput = document.getElementById('images-input');
    const shotsPreviewContainer = document.getElementById('shots-preview-container');

    imagesInput.addEventListener('change', function() {
        shotsPreviewContainer.innerHTML = '';
        if (this.files && this.files.length > 0) {
            const hasLargeFile = Array.from(this.files).some(file => file.size > MAX_SIZE);
            if (hasLargeFile) {
                alert('Uma ou mais imagens excedem o tamanho máximo de 2MB. Por favor, escolha imagens menores.');
                this.value = '';
                shotsPreviewContainer.classList.add('hidden');
                return;
            }

            shotsPreviewContainer.classList.remove('hidden');
            Array.from(this.files).forEach(file => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const div = document.createElement('div');
                    div.className = 'aspect-video rounded-xl overflow-hidden border border-gray-100 bg-white shadow-sm';
                    div.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-cover">`;
                    shotsPreviewContainer.appendChild(div);
                }
                reader.readAsDataURL(file);
            });
        } else {
            shotsPreviewContainer.classList.add('hidden');
        }
    });
</script>
{% endblock %}
