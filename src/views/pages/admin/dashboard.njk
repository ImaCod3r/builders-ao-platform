{% extends "layout/main.njk" %}

{% block title %}Dashboard Admin - Builders AO{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl sm:text-3xl font-black text-gray-900 border-l-4 border-brand-red pl-4 tracking-tight">Painel Administrativo</h1>
            <p class="text-gray-500 mt-1 text-sm sm:text-base">Gerencie as submissões da comunidade.</p>
        </div>
    </div>

    {% if success %}
        <div class="bg-green-50 text-green-700 border border-green-200 p-4 rounded-xl mb-6 flex items-center gap-3 animate-in fade-in duration-500" role="alert">
            <i data-lucide="check-circle-2" class="w-5 h-5"></i>
            <span class="text-sm font-medium">Projeto atualizado com sucesso ({{ success }}).</span>
        </div>
    {% endif %}

    {% if error %}
        <div class="bg-red-50 text-brand-red border border-red-200 p-4 rounded-xl mb-6 flex items-center gap-3 animate-in fade-in duration-500" role="alert">
            <i data-lucide="alert-circle" class="w-5 h-5"></i>
            <span class="text-sm font-medium">{{ error }}</span>
        </div>
    {% endif %}

    <div class="bg-white shadow-premium rounded-2xl overflow-hidden border border-gray-100">
        <div class="px-6 py-5 border-b border-gray-100 bg-gray-50/50 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <i data-lucide="clock" class="w-5 h-5 text-amber-500"></i>
                <h2 class="text-lg font-bold text-gray-800">Projetos Pendentes</h2>
            </div>
            <span class="bg-amber-100 text-amber-800 text-xs font-black px-2.5 py-1 rounded-full uppercase tracking-wider">{{ pendingProjects | length }}</span>
        </div>
        
        {% if pendingProjects and pendingProjects.length > 0 %}
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-100">
                <thead class="bg-white uppercase text-[10px] text-gray-400 font-black tracking-widest">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left">Projeto</th>
                        <th scope="col" class="px-6 py-4 text-left hidden sm:table-cell">Links & Tags</th>
                        <th scope="col" class="px-6 py-4 text-right">Ações</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-50">
                    {% for project in pendingProjects %}
                    <tr class="hover:bg-gray-50/50 transition-colors group">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex items-center gap-4">
                                <div class="relative shrink-0">
                                    <img src="{{ project.logo_url }}" alt="Logo {{ project.name }}" class="h-12 w-12 rounded-xl shadow-sm object-cover bg-white ring-1 ring-gray-100" onerror="this.src='https://ui-avatars.com/api/?name={{ project.name }}&background=E5E7EB&color=374151'">
                                </div>
                                <div>
                                    <div class="text-sm font-bold text-gray-900 group-hover:text-brand-red transition-colors">{{ project.name }}</div>
                                    <div class="sm:hidden mt-1 flex flex-col gap-1">
                                        <a href="{{ project.url }}" target="_blank" class="text-xs text-brand-red font-medium hover:underline">Visitar Site</a>
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 hidden sm:table-cell">
                            <div class="space-y-2">
                                <a href="{{ project.url }}" target="_blank" class="text-xs font-bold text-gray-400 hover:text-brand-red flex items-center gap-1.5 transition-colors">
                                    <i data-lucide="link" class="w-3 h-3"></i>
                                    {{ project.url | replace('https://', '') | replace('http://', '') | truncate(30) }}
                                </a>
                                <div class="flex flex-wrap gap-1">
                                    {% if project.taglines %}
                                        {% set tags = project.taglines.split(',') %}
                                        {% for tag in tags %}
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-[10px] font-bold bg-gray-50 text-gray-500 border border-gray-200/50">
                                                {{ tag | trim }}
                                            </span>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right">
                            <div class="flex items-center justify-end gap-2">
                                <!-- Botão de Aprovar -->
                                <form action="/admin/projects/{{ project.id }}/approve" method="POST" class="inline-block m-0">
                                    <button type="submit" class="bg-gray-900 hover:bg-green-600 text-white font-bold py-2 px-4 rounded-xl shadow-sm transition-all text-xs flex items-center gap-1.5 active:scale-95">
                                        <i data-lucide="check" class="w-3.5 h-3.5"></i>
                                        Aprovar
                                    </button>
                                </form>
                                <!-- Botão de Rejeitar -->
                                <form action="/admin/projects/{{ project.id }}/reject" method="POST" class="inline-block m-0">
                                    <button type="submit" class="bg-white border border-gray-200 text-gray-400 hover:text-red-600 hover:bg-red-50 font-bold py-2 px-4 rounded-xl transition-all text-xs flex items-center gap-1.5 active:scale-95" onclick="return confirm('Quer rejeitar o projeto {{ project.name }}?');">
                                        <i data-lucide="x" class="w-3.5 h-3.5"></i>
                                        <span class="hidden sm:inline">Rejeitar</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="py-16 px-6 text-center">
            <div class="w-16 h-16 bg-brand-light rounded-full flex items-center justify-center mx-auto mb-4 text-brand-red">
                <i data-lucide="check-check" class="w-8 h-8"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 uppercase tracking-tighter">Tudo organizado!</h3>
            <p class="mt-2 text-gray-500 text-sm max-w-xs mx-auto">Não há novos projetos aguardando revisão nesta fila.</p>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
