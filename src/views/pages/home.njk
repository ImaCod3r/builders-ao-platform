{% extends "layout/main.njk" %}

{% block title %}Início - Builders AO{% endblock %}

{% block content %}

<!-- Hero Section -->
<section class="relative py-20 overflow-hidden bg-white">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-brand-light/50 blur-[120px]"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-brand-light/30 blur-[120px]"></div>
    </div>
    
    <div class="container mx-auto px-4 relative z-10 text-center">
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-gray-900 mb-6">
            Descubra os melhores <br/>
            <span class="text-brand-red">Builders de Angola</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-500 max-w-2xl mx-auto mb-10 leading-relaxed">
            A vitrine para criadores, desenvolvedores e inovadores angolanos mostrarem seus produtos para o mundo.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/submit" class="bg-gray-900 text-white px-8 py-4 rounded-full font-bold shadow-xl hover:bg-black transition-all hover:scale-105 flex items-center gap-2">
                <i data-lucide="plus" class="w-5 h-5"></i>
                Enviar Produto
            </a>
            <a href="#feed" class="text-gray-600 font-semibold hover:text-gray-900 transition-colors flex items-center gap-2 px-8 py-4">
                Ver Galeria
                <i data-lucide="chevron-down" class="w-5 h-5 animate-bounce"></i>
            </a>
        </div>
    </div>
</section>

<!-- Feed Section -->
<div id="feed" class="max-w-5xl mx-auto px-4 pb-20 space-y-16">
    {% if projects and projects.length > 0 %}
        
        <!-- Seção: Destaques -->
        <div class="space-y-6">
            <div class="flex items-center gap-3">
                <div class="p-2 bg-brand-light rounded-lg">
                    <i data-lucide="star" class="w-5 h-5 text-brand-red fill-current"></i>
                </div>
                <h2 class="text-lg font-bold tracking-tight text-gray-900">Em Destaque</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for project in projects.slice(0, 6) %}
                    <a href="/product/{{ project.slug }}" class="group block bg-white border border-gray-100 p-5 rounded-2xl shadow-sm hover:shadow-premium hover:border-gray-200 transition-all duration-300">
                        <div class="flex items-start gap-4">
                            <!-- Logo -->
                            <div class="w-14 h-14 flex-shrink-0 bg-gray-50 rounded-xl flex items-center justify-center border border-gray-100 overflow-hidden group-hover:scale-105 transition-transform">
                                {% if project.logo_url %}
                                    <img src="{{ project.logo_url }}" alt="Logo {{ project.name }}" class="max-h-full max-w-full object-cover">
                                {% else %}
                                    <i data-lucide="image" class="w-6 h-6 text-gray-300"></i>
                                {% endif %}
                            </div>
                            <!-- Info -->
                            <div class="flex-grow min-w-0">
                                <h3 class="text-base font-bold text-gray-900 truncate mb-1">{{ project.name }}</h3>
                                <p class="text-xs text-gray-500 line-clamp-2 leading-relaxed">
                                    {% if project.taglines %}
                                        {{ project.taglines.split(',')[0] | trim }}
                                    {% else %}
                                        Inovação feita em Angola.
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </div>

        <!-- Seção: Todos os Produtos -->
        <div class="space-y-8">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="p-2 bg-gray-50 rounded-lg">
                        <i data-lucide="layout-grid" class="w-5 h-5 text-gray-600"></i>
                    </div>
                    <h2 class="text-2xl font-bold tracking-tight text-gray-900">Produtos da Comunidade</h2>
                </div>
            </div>

            <div class="flex flex-col gap-5">
                {% for project in projects %}
                    <div class="relative bg-white rounded-2xl shadow-sm border border-gray-100 p-5 sm:p-6 hover:shadow-premium hover:border-gray-200 transition-all duration-300 flex items-center gap-5 sm:gap-8 group">
                        
                        <a href="/product/{{ project.slug }}" class="absolute inset-0 z-10"><span class="sr-only">Ver produto {{ project.name }}</span></a>

                        <!-- Rank -->
                        <div class="hidden sm:flex text-gray-300 font-black text-2xl w-8 justify-center">
                            {{ loop.index }}
                        </div>

                        <!-- Logo Section -->
                        <div class="w-20 h-20 sm:w-24 sm:h-24 flex-shrink-0 bg-gray-50 rounded-2xl flex items-center justify-center border border-gray-100 overflow-hidden relative">
                            {% if project.logo_url %}
                                <img src="{{ project.logo_url }}" alt="Logo {{ project.name }}" class="max-h-full max-w-full object-cover">
                            {% else %}
                                <i data-lucide="package" class="w-10 h-10 text-gray-200"></i>
                            {% endif %}
                        </div>

                        <!-- Infos do Projeto -->
                        <div class="flex-grow min-w-0">
                            <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-brand-red transition-colors flex items-center gap-2">
                                {{ project.name }}
                                {% if loop.index <= 3 %}
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-brand-light text-brand-red border border-red-100">
                                        TOP
                                    </span>
                                {% endif %}
                            </h3>
                            
                            <p class="text-gray-500 text-sm mb-4 line-clamp-1 sm:line-clamp-2 leading-relaxed">
                                {% if project.taglines %}
                                    {{ project.taglines }}
                                {% else %}
                                    Nenhuma descrição disponível para este produto.
                                {% endif %}
                            </p>

                            <!-- Tags & Stats -->
                            <div class="flex flex-wrap items-center gap-3">
                                {% if project.taglines %}
                                    {% set tags = project.taglines.split(',') %}
                                    {% for tag in tags %}
                                        {% if loop.index0 < 2 %}
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-gray-50 text-gray-600 border border-gray-100">
                                                {{ tag | trim }}
                                            </span>
                                        {% endif %}
                                    {% endfor %}
                                {% endif %}
                                <div class="flex items-center gap-1.5 text-gray-400 text-xs ml-auto sm:ml-0">
                                    <i data-lucide="message-square" class="w-3.5 h-3.5"></i>
                                    <span>24</span>
                                </div>
                            </div>
                        </div>

                        <!-- Upvote Section -->
                        <div class="flex-shrink-0 relative z-20">
                            <button 
                                class="upvote-btn flex flex-col items-center justify-center min-w-[64px] h-16 sm:h-20 rounded-2xl border transition-all duration-200 {{ 'border-brand-red bg-brand-light text-brand-red' if project.has_upvoted else 'border-gray-100 bg-white text-gray-400 hover:border-brand-red hover:text-brand-red hover:bg-brand-light' }}"
                                data-id="{{ project.id }}"
                                data-is-logged="{{ 'true' if user else 'false' }}"
                                aria-label="Upvote">
                                <i data-lucide="chevron-up" class="w-6 h-6 mb-1 {{ 'animate-bounce' if not project.has_upvoted }}"></i>
                                <span class="font-bold text-sm upvote-count">{{ project.upvotes_count }}</span>
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>

    {% else %}
        <div class="col-span-full py-24 flex flex-col items-center justify-center bg-gray-50 rounded-3xl border border-dashed border-gray-200">
            <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-sm mb-6">
                <i data-lucide="search-x" class="w-10 h-10 text-gray-300"></i>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-2">Nenhum projeto encontrado!</h3>
            <p class="text-gray-500 text-center max-w-sm mb-8">Parece que ainda não há produtos nesta categoria. Que tal ser o primeiro?</p>
            <a href="/submit" class="bg-gray-900 text-white px-6 py-3 rounded-xl font-bold hover:bg-black transition flex items-center gap-2">
                <i data-lucide="plus" class="w-5 h-5"></i>
                Enviar Produto
            </a>
        </div>
    {% endif %}
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const upvoteBtns = document.querySelectorAll('.upvote-btn');
    
    upvoteBtns.forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const currentBtn = e.currentTarget;
            const productId = currentBtn.dataset.id;
            const isLogged = currentBtn.dataset.isLogged === 'true';

            if (!isLogged) {
                openModal(
                    'Upvote Necessário', 
                    'Faça login para apoiar este projeto angolano e ajudar na classificação dele no ranking.'
                );
                return;
            }
            
            // Add loading state
            currentBtn.classList.add('opacity-50', 'pointer-events-none');

            try {
                const response = await fetch(`/products/${productId}/upvote`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                if (response.status === 401 || response.status === 403) {
                    openModal('Sessão Expirada', 'Por favor, faça login novamente para continuar.');
                    return;
                }

                if (!response.ok) throw new Error('Falha ao processar upvote');

                const data = await response.json();
                
                const countSpan = currentBtn.querySelector('.upvote-count');
                countSpan.textContent = data.count;
                
                if (data.action === 'added') {
                    currentBtn.classList.remove('border-gray-100', 'bg-white', 'text-gray-400');
                    currentBtn.classList.add('border-brand-red', 'bg-brand-light', 'text-brand-red');
                } else if (data.action === 'removed') {
                    currentBtn.classList.remove('border-brand-red', 'bg-brand-light', 'text-brand-red');
                    currentBtn.classList.add('border-gray-100', 'bg-white', 'text-gray-400');
                }
            } catch (error) {
                console.error(error);
                // Notification (Toast placeholder)
                alert('Erro ao processar o seu upvote.');
            } finally {
                currentBtn.classList.remove('opacity-50', 'pointer-events-none');
            }
        });
    });
});
</script>

{% endblock %}
