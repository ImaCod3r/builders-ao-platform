{% extends "../layout/main.njk" %}

{% block content %}
<div class="container mx-auto px-4 mb-20 max-w-3xl mt-12">
  <div class="mb-8 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">
      Editar Post
    </h1>
    <p class="text-gray-500 mt-2">Altere o que for necessário no seu post.</p>
  </div>

  {% if error %}
    <div class="bg-red-50 text-red-700 border border-red-100 p-4 rounded-xl mb-6 font-medium">
      {{ error }}
    </div>
  {% endif %}

  <form action="/posts/{{ post.id }}/edit" method="POST" enctype="multipart/form-data" class="bg-white p-6 md:p-10 rounded-3xl border border-gray-200 shadow-premium space-y-6">
    
    <div>
      <label for="title" class="block text-sm font-bold text-gray-700 mb-2">Tí­tulo do Post</label>
      <input type="text" id="title" name="title" required value="{{ post.title }}"
        class="w-full bg-white border border-gray-300 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-all font-semibold text-lg"
        placeholder="Do que você quer falar?">
    </div>

    <div>
      <label for="content" class="block text-sm font-bold text-gray-700 mb-2">Conteúdo</label>
      <textarea id="content" name="content" rows="8" required
        class="w-full bg-white border border-gray-300 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-all resize-y"
        placeholder="Escreva os detalhes...">{{ post.content }}</textarea>
    </div>
    <div>
      <label class="block text-sm font-bold text-gray-700 mb-2">Imagens Atuais</label>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4" id="existing-images">
        {% for img_url in post.image_urls %}
          <div class="relative aspect-video rounded-xl overflow-hidden border border-gray-200 group">
            <img src="{{ img_url }}" class="w-full h-full object-cover">
            <input type="hidden" name="existing_images" value="{{ img_url }}">
            <button type="button" onclick="this.parentElement.remove()" class="absolute top-2 right-2 bg-red-500 text-white p-1 rounded-full opacity-0 group-hover:opacity-100 transition-opacity">
              <i data-lucide="x" class="w-4 h-4"></i>
            </button>
          </div>
        {% else %}
          <p class="text-sm text-gray-500 col-span-2">Nenhuma imagem atual.</p>
        {% endfor %}
      </div>

      <label for="images" class="block text-sm font-bold text-gray-700 mb-2 mt-6">Adicionar Novas Imagens</label>
      <div class="flex items-center justify-center w-full">
        <label for="images" class="flex flex-col items-center justify-center w-full h-32 border-2 border-gray-300 border-dashed rounded-xl cursor-pointer bg-gray-50 hover:bg-gray-100 hover:border-brand-red transition-colors">
          <div class="flex flex-col items-center justify-center pt-5 pb-6">
            <i data-lucide="image-plus" class="w-8 h-8 mb-3 text-gray-400"></i>
            <p class="mb-2 text-sm text-gray-500 font-medium"><span class="font-bold">Clique para enviar</span> ou arraste</p>
            <p class="text-xs text-gray-400">PNG, JPG, GIF até 2MB</p>
          </div>
          <input id="images" name="images" type="file" class="hidden" accept="image/*" multiple />
        </label>
      </div>
      <div id="image-previews" class="mt-4 grid grid-cols-2 md:grid-cols-4 gap-4 hidden"></div>
    </div>
    <div class="flex justify-end pt-4 border-t border-gray-100 mt-8">
      <a href="/feed" class="px-6 py-3 text-gray-500 hover:text-gray-900 font-medium transition-colors mr-4 flex items-center">
        Cancelar
      </a>
      <button type="submit"
        class="bg-brand-red hover:bg-brand-darkred text-white py-3 px-8 rounded-xl font-bold transition-all shadow-lg flex items-center gap-2">
        <i data-lucide="save" class="w-4 h-4"></i>
        Salvar
      </button>
    </div>
  </form>
</div>
{% endblock %}

{% block scripts %}
<script>
  const fileInput = document.getElementById('images');
  const fileDisplay = document.getElementById('image-previews');

  fileInput.addEventListener('change', () => {
    fileDisplay.innerHTML = ''; // Limpar previews anteriores
    
    if (fileInput.files.length > 0) {
      fileDisplay.classList.remove('hidden');
      
      Array.from(fileInput.files).forEach(file => {
        if (!file.type.startsWith('image/')) return;
        
        const fileReader = new FileReader();
        
        fileReader.onload = function(e) {
          const div = document.createElement('div');
          div.className = 'relative aspect-video rounded-xl overflow-hidden border border-gray-200';
          
          const img = document.createElement('img');
          img.src = e.target.result;
          img.className = 'w-full h-full object-cover';
          
          div.appendChild(img);
          fileDisplay.appendChild(div);
        }
        
        fileReader.readAsDataURL(file);
      });
      
    } else {
      fileDisplay.classList.add('hidden');
    }
  });
</script>
{% endblock %}