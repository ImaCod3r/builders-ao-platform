{% extends "layout/main.njk" %}

{% block title %}Meu Perfil - Builders AO{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto py-12 px-4">
    <div class="space-y-10">
        <div class="text-center">
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight mb-3">Editar Perfil</h1>
            <p class="text-gray-500 max-w-sm mx-auto">Mantenha suas informações atualizadas para que outros builders possam te encontrar.</p>
        </div>

        {% if error %}
            <div class="bg-red-50 text-brand-red border border-red-100 p-4 rounded-2xl flex items-center gap-3 animate-shake" role="alert">
                <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i>
                <span class="text-sm font-semibold">{{ error }}</span>
            </div>
        {% endif %}

        {% if success %}
            <div class="bg-green-50 text-green-600 border border-green-100 p-4 rounded-2xl flex items-center gap-3" role="alert">
                <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0"></i>
                <span class="text-sm font-semibold">Perfil atualizado com sucesso!</span>
            </div>
        {% endif %}

        <form action="/profile" method="POST" enctype="multipart/form-data" class="space-y-8 bg-white p-8 sm:p-10 rounded-3xl shadow-premium border border-gray-100 transition-all">
            
            <!-- Avatar Section -->
            <div class="space-y-4">
                <label class="text-sm font-bold text-gray-700 tracking-tight flex items-center gap-2">
                    <i data-lucide="camera" class="w-4 h-4 text-brand-red"></i>
                    Foto de Perfil
                </label>
                <div class="flex items-center gap-6 p-4 border-2 border-dashed border-gray-100 rounded-2xl bg-gray-50/50 group transition-colors hover:border-gray-200">
                    <div class="relative w-24 h-24 shrink-0 bg-white rounded-full flex items-center justify-center border border-gray-100 overflow-hidden shadow-sm shadow-gray-200/50">
                        <img id="avatar-preview" 
                             class="absolute inset-0 h-full w-full object-cover transition-opacity" 
                             src="{{ user.user_metadata.avatar_url | default('https://ui-avatars.com/api/?name=' + user.email + '&background=random') }}" 
                             alt="Sua foto de perfil" />
                    </div>
                    <div class="flex-grow">
                        <label class="cursor-pointer">
                            <span class="btn-shadcn bg-white hover:bg-gray-50 transition-all text-xs">Alterar Foto</span>
                            <input type="file" id="avatar-input" name="avatar" accept="image/*" class="sr-only"/>
                        </label>
                        <p class="text-[10px] text-gray-400 mt-2 font-medium uppercase tracking-wider">PNG, JPG ou WEBP. Máx 1MB.</p>
                    </div>
                </div>
            </div>

            <!-- Name Section -->
            <div class="space-y-2">
                <label for="full_name" class="text-sm font-bold text-gray-700 tracking-tight">Nome Completo</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i data-lucide="user" class="w-4 h-4 text-gray-300"></i>
                    </div>
                    <input type="text" id="full_name" name="full_name" required 
                           value="{{ user.user_metadata.full_name | default('') }}"
                           placeholder="Seu nome" 
                           class="w-full bg-gray-50 border border-gray-100 rounded-xl pl-11 pr-4 py-3.5 text-sm focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-red/10 focus:border-brand-red transition-all" />
                </div>
            </div>

            <!-- Email (Disabled) -->
            <div class="space-y-2 opacity-60">
                <label class="text-sm font-bold text-gray-700 tracking-tight">E-mail (Inalterável)</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i data-lucide="mail" class="w-4 h-4 text-gray-300"></i>
                    </div>
                    <input type="email" value="{{ user.email }}" disabled 
                           class="w-full bg-gray-100 border border-gray-100 rounded-xl pl-11 pr-4 py-3.5 text-sm cursor-not-allowed" />
                </div>
            </div>

            <!-- Botões de Ação -->
            <div class="pt-6 flex flex-col sm:flex-row items-center gap-3">
                <button type="submit" class="w-full sm:w-auto bg-gray-900 text-white px-8 py-4 rounded-xl font-bold hover:bg-black transition-all shadow-lg active:scale-95 flex items-center justify-center gap-2">
                    <i data-lucide="save" class="w-4 h-4"></i>
                    Salvar Alterações
                </button>
                <a href="/" class="w-full sm:w-auto text-center px-8 py-4 text-gray-500 font-bold hover:text-gray-900 transition-colors">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    const avatarInput = document.getElementById('avatar-input');
    const avatarPreview = document.getElementById('avatar-preview');

    avatarInput.addEventListener('change', function() {
        if (this.files && this.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                avatarPreview.src = e.target.result;
            }
            reader.readAsDataURL(this.files[0]);
        }
    });

    // Manually trigger lucide icons because they might have been added to the DOM and the script in main.njk already ran
    if (window.lucide) {
        lucide.createIcons();
    }
</script>
{% endblock %}
