{% extends "../layout/main.njk" %}

{% block content %}
<div class="container mx-auto px-4 max-w-3xl mb-20">
  
  <div class="flex justify-between items-center mb-10 mt-8">
    <div>
      <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">Feed da <span class="text-brand-red">Comunidade</span></h1>
      <p class="text-gray-500 mt-2">Descubra o que a comunidade está construindo e debatendo.</p>
    </div>
    {% if user %}
      <a href="/posts/create" class="bg-brand-red hover:bg-brand-darkred text-white px-6 py-3 rounded-xl font-bold transition-all shadow-lg flex items-center gap-2">
        <i data-lucide="pen-square" class="w-5 h-5"></i>
        Criar Post
      </a>
    {% endif %}
  </div>

  {% if success %}
    <div class="bg-green-50 text-green-700 p-4 rounded-xl mb-8 flex justify-between items-center border border-green-100 font-medium">
      <span>{{ success }}</span>
      <button onclick="this.parentElement.remove()" class="text-green-500 hover:text-green-700"><i data-lucide="x" class="w-5 h-5"></i></button>
    </div>
  {% endif %}

  {% if error %}
    <div class="bg-red-50 text-red-700 border border-red-100 p-4 rounded-xl mb-8 font-medium">
      {{ error }}
    </div>
  {% endif %}

  <div class="space-y-8">
    {% for post in posts %}
      <article class="bg-white border border-gray-100 rounded-2xl p-6 md:p-8 hover:border-gray-200 hover:shadow-premium transition-all duration-300">
        <!-- Post Header: Avatar, Name, Date -->
        <div class="flex items-center gap-4 mb-6">
          <img src="{{ post.users.avatar_url or 'https://api.dicebear.com/7.x/avataaars/svg?seed=' + post.users.id }}" 
               alt="{{ post.users.name }}" 
               class="w-12 h-12 rounded-full border border-gray-200 object-cover">
          <div>
            <h3 class="font-bold text-gray-900">{{ post.users.name }}</h3>
            <p class="text-xs text-gray-500">{{ post.created_at | date }}</p>
          </div>
        </div>

        <!-- Post Title & Content -->
        <h2 class="text-2xl font-bold text-gray-900 mb-4">{{ post.title }}</h2>
        
        <p class="text-gray-700 leading-relaxed mb-4 whitespace-pre-wrap break-words">{{ post.content | escape | nl2br }}</p>

        <!-- Galeria de Imagens -->
        {% if post.image_urls and post.image_urls.length > 0 %}
          <div class="grid gap-2 grid-cols-1 {% if post.image_urls.length > 1 %}sm:grid-cols-2{% endif %} mt-4 mb-4">
            {% for img_url in post.image_urls %}
              <div class="aspect-video w-full rounded-xl overflow-hidden bg-gray-50 border border-gray-100">
                <img src="{{ img_url }}" alt="Imagem do post" class="w-full h-full object-cover">
              </div>
            {% endfor %}
          </div>
        {% endif %}

        <!-- Post Footer: Upvotes -->
        <div class="mt-6 pt-4 border-t border-gray-100 flex items-center justify-between">
          <button 
            onclick="toggleUpvote('{{ post.id }}', this)"
            class="flex items-center gap-2 group {{ 'opacity-50 cursor-not-allowed' if not user }}"
            {{ 'disabled title="Faça login para curtir"' if not user }}
          >
            <div class="p-2 rounded-full transition-colors {{ 'bg-brand-light border-brand-red' if post.has_upvoted else 'bg-gray-50 border border-gray-100 group-hover:border-brand-red group-hover:bg-brand-light' }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="{{ '#dc2626' if post.has_upvoted else 'none' }}" class="transition-colors upvote-icon {{ 'stroke-brand-red' if post.has_upvoted else 'stroke-gray-400 group-hover:stroke-brand-red' }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path>
              </svg>
            </div>
            <span class="font-bold text-sm transition-colors upvote-count {{ 'text-brand-red' if post.has_upvoted else 'text-gray-500 group-hover:text-brand-red' }}">{{ post.upvote_count }}</span>
          </button>
        </div>
      </article>
    {% else %}
      <div class="text-center py-20 bg-gray-50 rounded-2xl border border-dashed border-gray-200">
        <i data-lucide="message-square-dashed" class="w-12 h-12 mx-auto text-gray-300 mb-4"></i>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Nenhum post ainda.</h3>
        <p class="text-gray-500">Seja o primeiro a compartilhar um artigo ou atualização!</p>
      </div>
    {% endfor %}
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
  async function toggleUpvote(postId, btnEl) {
    const isLogged = btnEl.hasAttribute('disabled');
    if (isLogged) {
        if(typeof openModal === 'function') openModal('Ação Necessária', 'Você precisa estar logado para curtir o post.');
        return;
    }

    const countEl = btnEl.querySelector('.upvote-count');
    const iconEl = btnEl.querySelector('.upvote-icon');
    const containerEl = iconEl.closest('div');
    
    let currentCount = parseInt(countEl.innerText);
    btnEl.classList.add('opacity-50', 'pointer-events-none');
    
    try {
      const response = await fetch(`/posts/${postId}/upvote`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      
      const data = await response.json();
      
      if (data.success) {
        if (data.action === 'added') {
          countEl.innerText = currentCount + 1;
          iconEl.classList.remove('stroke-gray-400');
          iconEl.classList.add('stroke-brand-red');
          iconEl.style.fill = '#dc2626'; // brand-red
          
          containerEl.classList.remove('bg-gray-50', 'border-gray-100');
          containerEl.classList.add('bg-brand-light', 'border-brand-red');
        } else if (data.action === 'removed') {
          countEl.innerText = Math.max(0, currentCount - 1);
          iconEl.classList.add('stroke-gray-400');
          iconEl.classList.remove('stroke-brand-red');
          iconEl.style.fill = 'none';

          containerEl.classList.add('bg-gray-50', 'border-gray-100');
          containerEl.classList.remove('bg-brand-light', 'border-brand-red');
        }
      } else {
        alert(data.error || "Erro ao curtir o post.");
      }
    } catch (e) {
      console.error(e);
      alert("Erro de comunicação com o servidor.");
    } finally {
        btnEl.classList.remove('opacity-50', 'pointer-events-none');
    }
  }
</script>
{% endblock %}
